<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Chill Guy Customs</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --ice: #dff4ff;
      --frost: #a8d8f0;
      --blue: #3a9fd1;
      --deep: #0a2540;
      --white: #f5faff;
      --accent: #7ee8ff;
      --glass: rgba(255,255,255,0.07);
      --glass-border: rgba(174, 225, 255, 0.2);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      background-color: #060f1a;
      color: var(--ice);
      font-family: 'DM Sans', sans-serif;
      overflow-x: hidden;
    }

    /* --- NOISE TEXTURE OVERLAY --- */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 1000;
      opacity: 0.4;
    }

    /* --- NAV --- */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 48px;
      backdrop-filter: blur(20px);
      background: rgba(6, 15, 26, 0.7);
      border-bottom: 1px solid var(--glass-border);
    }

    .nav-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.6rem;
      letter-spacing: 3px;
      background: linear-gradient(120deg, var(--white), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
    }

    .nav-links a {
      font-family: 'Space Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--frost);
      text-decoration: none;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--accent); }

    .nav-cta {
      background: linear-gradient(135deg, var(--blue), var(--accent));
      color: var(--deep) !important;
      padding: 10px 22px;
      border-radius: 6px;
      font-weight: 700 !important;
      font-family: 'Space Mono', monospace !important;
      font-size: 0.72rem !important;
      letter-spacing: 2px;
      text-decoration: none;
      transition: opacity 0.2s, transform 0.2s !important;
    }

    .nav-cta:hover { opacity: 0.85; transform: translateY(-1px); }

    /* --- HERO --- */
    .hero {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 140px 48px 80px;
      position: relative;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 80% 40%, rgba(58,159,209,0.18) 0%, transparent 60%),
        radial-gradient(ellipse 50% 50% at 20% 80%, rgba(126,232,255,0.08) 0%, transparent 55%),
        linear-gradient(180deg, #060f1a 0%, #081825 100%);
      z-index: 0;
    }

    /* Floating ice crystal shapes */
    .crystal {
      position: absolute;
      border: 1px solid rgba(126,232,255,0.15);
      border-radius: 2px;
      transform: rotate(45deg);
      z-index: 0;
      animation: float 8s ease-in-out infinite;
    }

    .crystal:nth-child(1) { width: 60px; height: 60px; top: 20%; right: 15%; animation-delay: 0s; opacity: 0.5; }
    .crystal:nth-child(2) { width: 30px; height: 30px; top: 60%; right: 30%; animation-delay: 2s; opacity: 0.3; }
    .crystal:nth-child(3) { width: 90px; height: 90px; top: 10%; right: 35%; animation-delay: 4s; opacity: 0.2; }
    .crystal:nth-child(4) { width: 20px; height: 20px; top: 75%; right: 10%; animation-delay: 1s; opacity: 0.4; }
    .crystal:nth-child(5) { width: 45px; height: 45px; top: 35%; right: 55%; animation-delay: 3s; opacity: 0.15; }

    @keyframes float {
      0%, 100% { transform: rotate(45deg) translateY(0); }
      50% { transform: rotate(45deg) translateY(-18px); }
    }

    .hero-tag {
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 20px;
      position: relative;
      z-index: 2;
      animation: fadeUp 0.8s ease forwards;
      opacity: 0;
    }

    .hero h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(4.5rem, 12vw, 10rem);
      line-height: 0.92;
      letter-spacing: 2px;
      position: relative;
      z-index: 2;
      animation: fadeUp 0.8s ease 0.15s forwards;
      opacity: 0;
    }

    .hero h1 span {
      background: linear-gradient(120deg, var(--white) 0%, var(--accent) 50%, var(--blue) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      display: block;
    }

    .hero-sub {
      font-size: 1.05rem;
      color: var(--frost);
      max-width: 480px;
      margin-top: 28px;
      line-height: 1.7;
      font-weight: 300;
      position: relative;
      z-index: 2;
      animation: fadeUp 0.8s ease 0.3s forwards;
      opacity: 0;
    }

    .hero-actions {
      display: flex;
      gap: 16px;
      margin-top: 40px;
      position: relative;
      z-index: 2;
      animation: fadeUp 0.8s ease 0.45s forwards;
      opacity: 0;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--blue), var(--accent));
      color: var(--deep);
      padding: 16px 36px;
      border-radius: 8px;
      font-family: 'Space Mono', monospace;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      text-decoration: none;
      transition: transform 0.2s, box-shadow 0.2s;
      box-shadow: 0 0 30px rgba(126,232,255,0.25);
    }

    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 0 50px rgba(126,232,255,0.4);
    }

    .btn-secondary {
      background: transparent;
      border: 1px solid var(--glass-border);
      color: var(--frost);
      padding: 16px 36px;
      border-radius: 8px;
      font-family: 'Space Mono', monospace;
      font-size: 0.78rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s;
    }

    .btn-secondary:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .scroll-hint {
      position: absolute;
      bottom: 40px;
      left: 48px;
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 3px;
      color: rgba(168,216,240,0.4);
      text-transform: uppercase;
      z-index: 2;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .scroll-hint::before {
      content: '';
      width: 40px;
      height: 1px;
      background: rgba(168,216,240,0.3);
      display: block;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* --- MARQUEE STRIP --- */
    .marquee-strip {
      overflow: hidden;
      padding: 16px 0;
      background: rgba(126,232,255,0.06);
      border-top: 1px solid var(--glass-border);
      border-bottom: 1px solid var(--glass-border);
    }

    .marquee-inner {
      display: flex;
      gap: 48px;
      width: max-content;
      animation: marquee 22s linear infinite;
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--frost);
    }

    .marquee-inner span { opacity: 0.5; }
    .marquee-inner strong { color: var(--accent); opacity: 1; }

    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* --- SECTION COMMONS --- */
    section { padding: 100px 48px; position: relative; }

    .section-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 16px;
    }

    .section-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(2.5rem, 5vw, 4.5rem);
      letter-spacing: 1px;
      line-height: 1;
      color: var(--white);
    }

    /* --- FEATURED CARDS --- */
    .cards-section { background: #070e1a; }

    .cards-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 60px;
    }

    .cards-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 24px;
    }

    .card-item {
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
      cursor: pointer;
    }

    .card-item:hover {
      transform: translateY(-8px) rotate(-0.5deg);
      box-shadow: 0 20px 60px rgba(58,159,209,0.2);
    }

    .card-image {
      width: 100%;
      aspect-ratio: 2.5/3.5;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }

    /* Simulated card designs */
    .card-img-1 {
      background: linear-gradient(135deg, #0d2137 0%, #1a4a6b 40%, #0e3050 100%);
    }
    .card-img-2 {
      background: linear-gradient(135deg, #071520 0%, #0e3a5c 50%, #1c6e8a 100%);
    }
    .card-img-3 {
      background: linear-gradient(135deg, #040d18 0%, #0b2640 50%, #1b5070 100%);
    }

    .card-mock {
      width: 75%;
      aspect-ratio: 2.5/3.5;
      border-radius: 10px;
      border: 1px solid rgba(126,232,255,0.3);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.1);
    }

    .card-mock::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(126,232,255,0.12) 0%, transparent 50%, rgba(58,159,209,0.08) 100%);
    }

    .card-mock-logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 3px;
      color: var(--accent);
      text-align: center;
      z-index: 1;
    }

    .card-mock-number {
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem;
      color: rgba(168,216,240,0.5);
      letter-spacing: 2px;
      margin-top: 6px;
      z-index: 1;
    }

    .card-shine {
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.06) 50%, transparent 70%);
      transform: rotate(30deg);
    }

    .card-item:hover .card-shine {
      animation: shine 0.6s ease forwards;
    }

    @keyframes shine {
      from { transform: rotate(30deg) translateX(-100%); }
      to { transform: rotate(30deg) translateX(100%); }
    }

    .card-info {
      padding: 20px;
    }

    .card-info h3 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.3rem;
      letter-spacing: 1px;
      color: var(--white);
      margin-bottom: 6px;
    }

    .card-info p {
      font-size: 0.82rem;
      color: rgba(168,216,240,0.6);
      margin-bottom: 14px;
    }

    .card-tag {
      display: inline-block;
      background: rgba(126,232,255,0.1);
      border: 1px solid rgba(126,232,255,0.2);
      color: var(--accent);
      font-family: 'Space Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 2px;
      padding: 4px 10px;
      border-radius: 4px;
      text-transform: uppercase;
    }

    /* --- PROCESS --- */
    .process-section {
      background: linear-gradient(180deg, #070e1a 0%, #060f1a 100%);
    }

    .process-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 2px;
      margin-top: 60px;
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      overflow: hidden;
    }

    .process-step {
      padding: 40px 32px;
      background: var(--glass);
      border-right: 1px solid var(--glass-border);
      transition: background 0.3s;
    }

    .process-step:last-child { border-right: none; }
    .process-step:hover { background: rgba(126,232,255,0.05); }

    .step-number {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 3.5rem;
      line-height: 1;
      color: rgba(126,232,255,0.12);
      margin-bottom: 16px;
    }

    .step-icon {
      font-size: 1.6rem;
      margin-bottom: 14px;
    }

    .process-step h3 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.4rem;
      letter-spacing: 1px;
      color: var(--white);
      margin-bottom: 10px;
    }

    .process-step p {
      font-size: 0.85rem;
      color: rgba(168,216,240,0.55);
      line-height: 1.7;
    }

    /* --- STATS --- */
    .stats-section {
      background: linear-gradient(135deg, rgba(58,159,209,0.08) 0%, rgba(126,232,255,0.04) 100%);
      border-top: 1px solid var(--glass-border);
      border-bottom: 1px solid var(--glass-border);
      padding: 80px 48px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 40px;
      text-align: center;
    }

    .stat-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3rem, 6vw, 5rem);
      background: linear-gradient(120deg, var(--white), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      line-height: 1;
    }

    .stat-label {
      font-family: 'Space Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: rgba(168,216,240,0.45);
      margin-top: 8px;
    }

    /* --- TESTIMONIALS --- */
    .testimonials-section { background: #060f1a; }

    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
      margin-top: 60px;
    }

    .testimonial {
      background: var(--glass);
      border: 1px solid var(--glass-border);
      border-radius: 16px;
      padding: 32px;
      transition: border-color 0.3s;
    }

    .testimonial:hover { border-color: rgba(126,232,255,0.35); }

    .testimonial-stars {
      color: var(--accent);
      font-size: 0.85rem;
      letter-spacing: 2px;
      margin-bottom: 16px;
    }

    .testimonial p {
      font-size: 0.92rem;
      color: var(--frost);
      line-height: 1.75;
      font-style: italic;
      margin-bottom: 20px;
    }

    .testimonial-author {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .author-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--blue), var(--accent));
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1rem;
      color: var(--deep);
    }

    .author-name {
      font-weight: 600;
      font-size: 0.88rem;
      color: var(--white);
    }

    .author-handle {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      color: rgba(168,216,240,0.4);
      letter-spacing: 1px;
    }

    /* --- CTA --- */
    .cta-section {
      text-align: center;
      padding: 120px 48px;
      background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(58,159,209,0.14) 0%, transparent 70%);
      border-top: 1px solid var(--glass-border);
    }

    .cta-section .section-label { justify-content: center; display: block; }

    .cta-section .section-title {
      font-size: clamp(3rem, 7vw, 6rem);
      margin-bottom: 20px;
    }

    .cta-section p {
      color: var(--frost);
      font-size: 1rem;
      max-width: 500px;
      margin: 0 auto 40px;
      font-weight: 300;
      line-height: 1.7;
    }

    .cta-buttons {
      display: flex;
      gap: 16px;
      justify-content: center;
    }

    /* --- FOOTER --- */
    footer {
      background: #040b14;
      border-top: 1px solid var(--glass-border);
      padding: 60px 48px 40px;
    }

    .footer-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 48px;
    }

    .footer-brand .nav-logo { font-size: 1.8rem; }

    .footer-brand p {
      font-size: 0.83rem;
      color: rgba(168,216,240,0.4);
      max-width: 240px;
      margin-top: 12px;
      line-height: 1.6;
    }

    .footer-links {
      display: flex;
      gap: 80px;
    }

    .footer-col h4 {
      font-family: 'Space Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 20px;
    }

    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: 10px; }
    .footer-col ul li a {
      font-size: 0.85rem;
      color: rgba(168,216,240,0.5);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-col ul li a:hover { color: var(--accent); }

    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 1px solid var(--glass-border);
      padding-top: 28px;
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 2px;
      color: rgba(168,216,240,0.25);
      text-transform: uppercase;
    }

    /* --- RESPONSIVE --- */
    @media (max-width: 768px) {
      nav { padding: 16px 24px; }
      .nav-links { display: none; }
      section, .hero { padding: 80px 24px; }
      .hero { padding-top: 120px; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .footer-top { flex-direction: column; gap: 40px; }
      .footer-links { gap: 40px; }
      .footer-bottom { flex-direction: column; gap: 10px; text-align: center; }
      .cards-header { flex-direction: column; align-items: flex-start; gap: 20px; }
    }
  </style>
</head>
