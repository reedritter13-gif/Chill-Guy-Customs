      <span>Collector Grade</span><strong>✦</strong>
      <span>Basketball</span><strong>✦</strong>
      <span>Football</span><strong>✦</strong>
      <span>Baseball</span><strong>✦</strong>
    </div>
  </div>

  <!-- CARDS -->
  <section class="cards-section" id="cards">
    <div class="cards-header">
      <div>
        <p class="section-label">Featured Work</p>
        <h2 class="section-title">Recent Customs</h2>
      </div>
      <a href="#contact" class="btn-secondary">Commission a Card →</a>
    </div>
    <div class="cards-grid">
